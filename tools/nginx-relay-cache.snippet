# nginx snippet: expose relay-cache on relay.bitcraftsync.app
#
# Insert these blocks in the HTTPS `server { ... }` for
# relay.bitcraftsync.app, BEFORE the catch-all `location /`
# (which proxies to relay-coordinator on 127.0.0.1:8082).
#
# Install on the host:
#   1. Backup: sudo cp /etc/nginx/sites-available/relay.bitcraftsync.app.conf \
#        /etc/nginx/sites-available/relay.bitcraftsync.app.conf.bak-cache-$(date +%Y%m%d-%H%M%S)
#   2. Paste the blocks below before `location /`
#   3. sudo nginx -t && sudo nginx -s reload
#
# Public URLs (binary remains on 127.0.0.1:8089):
#   https://relay.bitcraftsync.app/cache-health
#   https://relay.bitcraftsync.app/proto
#   https://relay.bitcraftsync.app/proto/relay_cache.proto
#   https://relay.bitcraftsync.app/claim?name=...
#   https://relay.bitcraftsync.app/claim/<id>
#   https://relay.bitcraftsync.app/claim/<id>/inventory
#   wss://relay.bitcraftsync.app/claim/<id>/inventory/ws
#   https://relay.bitcraftsync.app/claim/<id>/members
#   https://relay.bitcraftsync.app/claim/<id>/citizens
#   https://relay.bitcraftsync.app/claim/<id>/hexcoins
#   https://relay.bitcraftsync.app/claim/<id>/crafts
#   https://relay.bitcraftsync.app/player?name=...
#   https://relay.bitcraftsync.app/player/<id>
#   https://relay.bitcraftsync.app/player/<id>/inventory
#   wss://relay.bitcraftsync.app/player/<id>/inventory/ws
#   https://relay.bitcraftsync.app/player/<id>/housing
#   wss://relay.bitcraftsync.app/player/<id>/housing/ws
#   https://relay.bitcraftsync.app/player/<id>/skills
#   https://relay.bitcraftsync.app/player/<id>/crafts
#   https://relay.bitcraftsync.app/deposits
#   https://relay.bitcraftsync.app/deposits?region=14
#   https://relay.bitcraftsync.app/storage-logs?storageId=...
#   https://relay.bitcraftsync.app/storage-logs?playerId=...
#   https://relay.bitcraftsync.app/storage-logs?itemId=...&claimId=...
#
# Requires the usual Upgrade map in http {} (already present for relay
# frontends):
#   map $http_upgrade $connection_upgrade {
#       default upgrade;
#       ''      close;
#   }

    # relay-cache (loopback read API)
    location /cache-health {
        proxy_pass http://127.0.0.1:8089;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /proto {
        proxy_pass http://127.0.0.1:8089;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /claim {
        proxy_pass http://127.0.0.1:8089;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Live inventory WS (/claim/:id/inventory/ws) + large HTTP inventories
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location /player {
        proxy_pass http://127.0.0.1:8089;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Live inventory WS (/player/:id/inventory/ws, /housing/ws)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location /deposits {
        proxy_pass http://127.0.0.1:8089;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /storage-logs {
        proxy_pass http://127.0.0.1:8089;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Busy chests / players can return multi-MB retained windows
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
